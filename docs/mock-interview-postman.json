{
    "info": {
      "name": "Mock Interview API",
      "_postman_id": "8e9f3b0b-4a0b-4af7-9e2d-0f4d2e8f2a11",
      "description": "Basic API checks for Mock Interview backend",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      {
        "key": "baseUrl",
        "value": "http://127.0.0.1:8000"
      }
    ],
    "item": [
      {
        "name": "Create Session - Valid",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"difficulty\": \"medium\"\n}"
          },
          "url": {
            "raw": "{{baseUrl}}/api/sessions/",
            "host": [
              "{{baseUrl}}"
            ],
            "path": [
              "api",
              "sessions",
              ""
            ]
          },
          "description": "Should return 201 with id, difficulty, status, created_at"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 201', function () {",
                "    pm.response.to.have.status(201);",
                "});",
                "",
                "const jsonData = pm.response.json();",
                "",
                "pm.test('Response has required fields', function () {",
                "    pm.expect(jsonData).to.have.property('id');",
                "    pm.expect(jsonData).to.have.property('difficulty');",
                "    pm.expect(jsonData).to.have.property('status');",
                "    pm.expect(jsonData).to.have.property('created_at');",
                "});",
                "",
                "pm.test('difficulty is medium', function () {",
                "    pm.expect(jsonData.difficulty).to.eql('medium');",
                "});",
                "",
                "pm.test('status is draft', function () {",
                "    pm.expect(jsonData.status).to.eql('draft');",
                "});",
                "",
                "pm.collectionVariables.set('sessionId', jsonData.id);"
              ]
            }
          }
        ]
      },
