              {
                "key": "file",
                "type": "file",
                "src": ""
              }
            ]
          },
          "url": {
            "raw": "{{baseUrl}}/api/sessions/{{sessionId}}/resume/",
            "host": ["{{baseUrl}}"],
            "path": ["api", "sessions", "{{sessionId}}", "resume", ""]
          },
          "description": "Upload resume file (.pdf/.docx) for a session"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "const jsonData = pm.response.json();",
                "pm.test('Response has session_id and resume_id', function () {",
                "  pm.expect(jsonData).to.have.property('session_id');",
                "  pm.expect(jsonData).to.have.property('resume_id');",
                "});"
              ]
            }
          }
        ]
      },
      {
        "name": "Get Session Detail",
        "request": {
          "method": "GET",
          "url": {
            "raw": "{{baseUrl}}/api/sessions/{{sessionId}}/",
            "host": ["{{baseUrl}}"],
            "path": ["api", "sessions", "{{sessionId}}", ""]
          },
          "description": "Fetch session details, resume metadata, and ordered question IDs"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "",
                "const jsonData = pm.response.json();",
                "",
                "pm.test('Response has session key', function () {",
                "  pm.expect(jsonData).to.have.property('session');",
                "});",
                "",
                "pm.test('Response has resume key', function () {",
                "  pm.expect(jsonData).to.have.property('resume');",
                "});",
                "",
                "pm.test('Response has question_ids array', function () {",
                "  pm.expect(jsonData).to.have.property('question_ids');",
                "  pm.expect(jsonData.question_ids).to.be.an('array');",
                "});"
              ]
            }
          }
        ]
      },
      {
        "name": "Generate Questions - Mock",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"resume_text\": \"Python Django React\",\n  \"difficulty\": \"medium\",\n  \"num_questions\": 3\n}"
          },
          "url": {
            "raw": "http://127.0.0.1:8001/generate-questions",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "8001",
            "path": ["generate-questions"]
          },
          "description": "Mock question generation endpoint test"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "",
                "const jsonData = pm.response.json();",
                "pm.test('questions is an array', function () {",
                "  pm.expect(jsonData).to.have.property('questions');",
                "  pm.expect(jsonData.questions).to.be.an('array');",
                "});",
                "pm.test('questions count is 3', function () {",
                "  pm.expect(jsonData.questions.length).to.eql(3);",
                "});"
              ]
            }
          }
        ]
      },
      {
        "method": "POST",
        "url": "http://127.0.0.1:8001/evaluate-session",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "difficulty": "medium",
          "items": [
            {
              "question": "Tell me about Python decorators",
              "answer": "Decorators wrap functions to add behavior like logging."
            },
            {
              "question": "How does Django ORM help?",
              "answer": "It maps database tables to Python models and simplifies queries."
            }
          ]
        }
      },
      {
        "name": "Evaluate Session",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"difficulty\": \"medium\",\n  \"items\": [\n    {\n      \"question\": \"Tell me about Python decorators\",\n      \"answer\": \"Decorators wrap functions to add behavior like logging.\"\n    },\n    {\n      \"question\": \"How does Django ORM help?\",\n      \"answer\": \"It maps database tables to Python models and simplifies queries.\"\n    }\n  ]\n}"
          },
          "url": {
            "raw": "http://127.0.0.1:8001/evaluate-session",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "8001",
            "path": ["evaluate-session"]
          },
          "description": "Evaluate Q&A with Groq and return total_score, overall_feedback, per_question"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "",
                "const jsonData = pm.response.json();",
                "pm.test('Response has required keys', function () {",
                "  pm.expect(jsonData).to.have.property('total_score');",
                "  pm.expect(jsonData).to.have.property('overall_feedback');",
                "  pm.expect(jsonData).to.have.property('per_question');",
                "});",
                "pm.test('per_question is array', function () {",
                "  pm.expect(jsonData.per_question).to.be.an('array');",
                "});"
              ]
            }
          }
        ]
      },
      {
